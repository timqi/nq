#!/bin/bash

if [ $# -eq 0 ]; then
    echo "No hosts specified"
    exit 0
fi

ssh="ssh -A"
TERM_MODE="${TSSH_TERMINAL:-${TERM_PROGRAM:-alacritty}}"
TERM_MODE="ghostty"

case "$TERM_MODE" in
    ghostty) tmux="/opt/homebrew/bin/tmux" ;;
    *)       tmux="/opt/homebrew/bin/tmux -L alacritty" ;;
esac

host0=$1
shift
if [ $# -eq 0 ]; then
    if [[ "$host0" == aws* || "$host0" == ali* || "$host0" == hw* ]]; then
        title=${host0#*-}
        tmp=${title#*-}
        title="${title%%-*}.${tmp//-/}"
    else
        title=$host0
    fi

    #if [ "$host0" = "g1" ]; then
    #    ssh="mosh --ssh='ssh -A'"
    #fi

    if [ "$TERM_MODE" = "ghostty" ]; then
        osascript <<EOF
tell application "Ghostty"
    set matches to every tab of front window whose name contains "$title"
    if (count of matches) > 0 then
        select tab (item 1 of matches)
    else
        set cfg to (new surface configuration)
        set command of cfg to "$ssh $host0"
        set t to (new tab in front window with configuration cfg)
        perform action "set_tab_title:$title" on focused terminal of t
    end if
end tell
EOF
    else
        line=$($tmux list-windows -a | grep "$title" | head -n 1)
        if [ -z "$line" ]; then
            $tmux new-window -e SSH_AUTH_SOCK=$SSH_AUTH_SOCK -n "$title" $ssh $host0
        else
            target="${line%:* *}"
            $tmux switch-client -t "$target"
        fi
    fi

    exit 0
fi

$tmux new-window -e SSH_AUTH_SOCK=$SSH_AUTH_SOCK -n ssh.m $ssh $host0
for host in "$@"; do
    echo $host
    $tmux split-window -h $ssh "$host"
    $tmux select-layout even-horizontal
done
if [ $# -eq 2 ]; then
    $tmux select-layout even-vertical
else
    $tmux select-layout tiled
fi
$tmux select-pane -t 1
$tmux setw synchronize-panes
