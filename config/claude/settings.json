{
  "env": {
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "1"
  },
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Bash(gh:*)",
      "Bash(glab:*)",
      "Bash(uv:*)",
      "Bash(codex:*)",
      "Bash(git:*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.last_assistant_message // empty' | head -1 | grep '^📝' | sed 's/^📝 *//' | { read -r line; [ -n \"$line\" ] && echo \"[$(date '+%Y-%m-%d %H:%M:%S')] $line\" >> ~/.claude/english-corrections.log; } || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/qiqi/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}